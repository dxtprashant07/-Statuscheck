# Copy this file to ".env" and fill in real values. docker compose reads .env automatically.
# NEVER commit the real .env.

# --- Database ---
DB_NAME=statusreport
DB_USER=statusreport
DB_PASSWORD=change-me-to-a-strong-db-password

# --- Auth (JWT) --- must be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# --- LLM provider ---
GROQ_API_KEY=gsk_your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant         # optional; default shown

# --- Web ---
# Public origin the browser uses to reach the app (used for CORS). Must match how
# you open the site. For local Docker this is http://localhost:8081.
APP_CORS_ALLOWED_ORIGINS=http://localhost:8081
FRONTEND_PORT=8081
